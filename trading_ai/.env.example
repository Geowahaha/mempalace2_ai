# Copy to .env and fill in. Never commit real secrets.

# --- Runtime ---
INSTANCE_NAME=mempalac
DRY_RUN=true
LIVE_EXECUTION_ENABLED=false
LOOP_INTERVAL_SEC=30
SYMBOL=XAUUSD
DATA_DIR=./data
RUNTIME_STATE_PATH=./data/runtime_state.json
STRATEGY_REGISTRY_PATH=./data/strategy_registry.json
DEFAULT_VOLUME=0.01

# --- Strategy evolution v2 (opt-in: global top-N / aging / vol weights tighten the funnel) ---
STRATEGY_EVOLUTION_V2_ENABLED=false
STRATEGY_GLOBAL_TOP_N=10
STRATEGY_EXPLORATION_MAX_TRADES=5
STRATEGY_AGING_ENABLED=false
STRATEGY_AGING_FACTOR=0.995
STRATEGY_CAPITAL_WEIGHTING_ENABLED=false
STRATEGY_CAPITAL_POOL=5
STRATEGY_CAPITAL_MULT_MIN=0.25
STRATEGY_CAPITAL_MULT_MAX=2.0

# --- Portfolio intelligence / correlation (opt-in GPT-style layers) ---
PORTFOLIO_INTELLIGENCE_ENABLED=false
PORTFOLIO_WEIGHT_LLM=1.0
PORTFOLIO_WEIGHT_MEMORY=0.55
PORTFOLIO_WEIGHT_STRUCTURE=0.35
PORTFOLIO_TIE_MARGIN=0.08
# Set e.g. 0.85 so very confident LLM cannot be out-voted on direction flip
PORTFOLIO_LLM_ANCHOR_CONFIDENCE=0.0

# Level 5: only applies when PORTFOLIO_INTELLIGENCE_ENABLED=true
CORRELATION_ENGINE_ENABLED=false
STRATEGY_CORRELATION_PATH=./data/strategy_correlation.json
CORRELATION_MAX_HISTORY=100
CORRELATION_MIN_SAMPLES=10
CORRELATION_PENALTY_MID=0.3
CORRELATION_PENALTY_HIGH=0.5
CORRELATION_PENALTY_MID_THRESHOLD=0.8
CORRELATION_PENALTY_HIGH_THRESHOLD=0.9
CORRELATION_MAX_PENALTY=0.7
CORRELATION_DIVERSITY_BONUS=0.1
CORRELATION_DIVERSITY_THRESHOLD=0.2

# --- Performance monitor (measurement / tuning) ---
PERFORMANCE_MONITOR_ENABLED=true
PERFORMANCE_LOG_INTERVAL=50
# Set >0 to warn on deep drawdown (same units as PnL / equity curve)
PERFORMANCE_ALERT_MAX_DRAWDOWN=0
PERFORMANCE_ALERT_SELECTIVITY_MIN=0.03
PERFORMANCE_ALERT_MIN_LLM_INTENTS=40
PERFORMANCE_STAGE_TELEMETRY_ENABLED=true
PERFORMANCE_STAGE_WARN_MS=1200
PERFORMANCE_CYCLE_WARN_MS=8000
# Debug mode: force "Performance stages" log on every cycle.
PERFORMANCE_STAGE_LOG_EVERY_CYCLE=false

# --- Backtest learning supervisor (Hermes research lane) ---
BACKTEST_LEARNING_ENABLED=false
BACKTEST_LEARNING_INTERVAL_SEC=21600
BACKTEST_LEARNING_FAILURE_BACKOFF_SEC=1800
BACKTEST_LEARNING_LOOKBACK_DAYS=7
BACKTEST_LEARNING_END_OFFSET_DAYS=1
BACKTEST_LEARNING_TIMEZONE=Asia/Bangkok
BACKTEST_LEARNING_TIMEFRAME=5m
BACKTEST_LEARNING_SOURCE_POLICY=real_first
BACKTEST_LEARNING_DEXTER_ROOT=../dexter_pro_v3_fixed/dexter_pro_v3_fixed
BACKTEST_LEARNING_OUTPUT_ROOT=./data/backtests_auto
BACKTEST_LEARNING_TIMEOUT_SEC=1800
BACKTEST_LEARNING_POLICY_APPLY_ENABLED=true
BACKTEST_LEARNING_POLICY_MAX_SHIFT=0.06
BACKTEST_LEARNING_MIN_CLOSED_TRADES=12
BACKTEST_LEARNING_MIN_WIN_RATE=0.50
BACKTEST_LEARNING_MIN_AVG_PROFIT=0.0
BACKTEST_LEARNING_MAX_DRAWDOWN=1.2
BACKTEST_LEARNING_POLICY_PATH=./data/backtest_learning_policy.json
BACKTEST_LEARNING_STATE_PATH=./data/backtest_learning_state.json
BACKTEST_LEARNING_SUMMARY_PATH=./data/backtest_learning_summary.md

# --- LLM (openai | mimo | local) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=google/gemma-4-26b-a4b-it:free
OPENAI_FALLBACK_MODELS=google/gemma-4-31b-it:free,openrouter/free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

MIMO_API_KEY=
# Alias accepted too: MIMO_API=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro

LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL_NAME=qwen2.5
LOCAL_API_KEY=ollama

LLM_TIMEOUT_SEC=120
LLM_MAX_RETRIES=1
LLM_FALLBACK_ENABLED=true
LLM_FAILOVER_FAILURE_THRESHOLD=2
LLM_FAILOVER_COOLDOWN_SEC=20
LLM_FAILOVER_RUNTIME_PATH=./data/llm_failover_runtime.json

# Optional dedicated Hermes/self-improvement lane
SELF_IMPROVEMENT_ENABLED=true
# SELF_IMPROVEMENT_MODEL_NAME=gemma3:1b-it-qat
# SELF_IMPROVEMENT_TIMEOUT_SEC=90
# SELF_IMPROVEMENT_MAX_TOKENS=220
# SELF_IMPROVEMENT_LOCAL_NUM_CTX=512
# SELF_IMPROVEMENT_LOCAL_KEEP_ALIVE=0s
# SELF_IMPROVEMENT_LOCAL_THINK=false

# --- Memory ---
MEMORY_BACKEND=chroma
CHROMA_PATH=./data/chroma_trading
# MEMORY_BACKEND=mempalace_chroma
# MEMPALACE_CHROMA_PATH=C:/Users/you/.mempalace/chroma
MEMORY_COLLECTION=trading_experiences
RECALL_TOP_K=8
MEMORY_SCORE_WEIGHT=0.35
MEMORY_WAKEUP_TOP_K=6
MEMORY_NOTE_TOP_K=6
MEMORY_ROOM_GUARD_ENABLED=true
MEMORY_ROOM_GUARD_BLOCK_ANTI=true

# --- Risk ---
MAX_TRADES_PER_SESSION=50
MAX_CONSECUTIVE_LOSSES=5
NEUTRAL_PNL_THRESHOLD=0.0001
MIN_TRADE_CONFIDENCE=0.65
ADAPTIVE_CONFIDENCE_FLOOR_ENABLED=true
ADAPTIVE_CONFIDENCE_FLOOR_DELTA_STRONG=0.05
ADAPTIVE_CONFIDENCE_FLOOR_DELTA_WEAK=0.05
ADAPTIVE_CONFIDENCE_FLOOR_MIN=0.55
ADAPTIVE_CONFIDENCE_FLOOR_MAX=0.80
ENTRY_LOSS_STREAK_BLOCK=3
PRICE_HISTORY_MAX=96
SIMILAR_TRADES_TOP_K=5

# --- Pattern intelligence ---
PATTERN_MIN_WIN_RATE=0.55
PATTERN_MIN_SAMPLE_SIZE=5
PATTERN_BOOST_MIN_WIN_RATE=0.65
PATTERN_BOOST_MIN_SAMPLE=10
PATTERN_CONFIDENCE_BOOST_DELTA=0.1
PATTERN_CONFIDENCE_CAP=0.95
# 0/false: allow trades when no pattern bucket exists yet (needed for first live orders)
PATTERN_GATE_STRICT=false
# Waive volatility/trend hard-vetoes until price_history has this many closes (paper/prime is RANGE early)
HARD_FILTER_MIN_CLOSES=12
# Adaptive hard-filter: only soften selected hard-vetoes when weekly lane outcomes support it.
HARD_FILTER_ADAPTIVE_ENABLED=true
HARD_FILTER_ADAPTIVE_MIN_TRADES=3
HARD_FILTER_ADAPTIVE_SUPPORT_EDGE_MIN=1
HARD_FILTER_ADAPTIVE_MIN_OPPORTUNITY=0.66
HARD_FILTER_ADAPTIVE_MAX_RISK=0.58
HARD_FILTER_ADAPTIVE_MIN_EDGE=0.10
HARD_FILTER_ADAPTIVE_MIN_IMPULSE_SUPPORT=0.66
HARD_FILTER_ADAPTIVE_MAX_LOSS_RATE=0.62
HARD_FILTER_ADAPTIVE_RECENT_WINDOW=8
HARD_FILTER_ADAPTIVE_RECENT_MIN_SAMPLES=4
HARD_FILTER_ADAPTIVE_RECENT_NEG_EDGE_BLOCK=-0.25
HARD_FILTER_ADAPTIVE_RECENT_POS_EDGE_BONUS=0.20

# --- cTrader Open API (optional) ---
# Real protobuf execution is NOT wired in Mempalac yet (integration stub).
# For live/demo orders use Dexter Pro with the same Dexter .env.local.
#
# --- Real demo/live orders: Dexter Open API worker ---
# 1) Dexter repo must exist; worker loads OAuth from Dexter `.env.local` (same machine recommended).
# 2) CTRADER_ACCOUNT_ID = numeric ctidTraderAccountId (Open API), NOT the visible cTrader login — get from broker/API.
# 3) Use Dexter venv python if import fails: CTRADER_WORKER_PYTHON=.../dexter_pro_v3_fixed/.venv/Scripts/python.exe
CTRADER_DEXTER_WORKER=0
# CTRADER_WORKER_SCRIPT=D:/dexter_pro_v3_fixed/dexter_pro_v3_fixed/ops/ctrader_execute_once.py
CTRADER_WORKER_PYTHON=
CTRADER_WORKER_TIMEOUT_SEC=120
CTRADER_QUOTE_SOURCE=auto
CTRADER_QUOTE_CACHE_TTL_SEC=2
CTRADER_QUOTE_SOFT_STALE_TTL_SEC=15
CTRADER_QUOTE_BACKGROUND_REFRESH_ENABLED=true
CTRADER_CAPTURE_DURATION_SEC=3
CTRADER_CAPTURE_MAX_EVENTS=18
CTRADER_WORKER_VOLUME_SCALE=100
CTRADER_USE_DEMO=1
CTRADER_ENABLED=0
OpenAPI_ClientID=
OpenAPI_Secreat=
OpenAPI_Access_token_API_key3=
OpenAPI_Refresh_token_API_key3=
CTRADER_OPENAPI_REDIRECT_URI=http://localhost
CTRADER_ACCOUNT_ID=
CTRADER_ACCOUNT_LOGIN=
#
# Legacy / short aliases (also accepted by config.py):
# CTRADER_CLIENT_ID=
# CTRADER_CLIENT_SECRET=
# CTRADER_ACCESS_TOKEN=
# CTRADER_DEMO=true

# --- HTTP API (api.py) ---
API_HOST=0.0.0.0
API_PORT=8091
